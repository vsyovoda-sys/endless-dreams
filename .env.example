# Database (SQLite for local; switch to Turso/libSQL for production)
DATABASE_URL="file:./dev.db"

# Second Me OAuth2
SECONDME_CLIENT_ID=
SECONDME_CLIENT_SECRET=
SECONDME_API_BASE=https://api.mindverse.com/gate/lab
SECONDME_OAUTH_URL=https://app.secondme.io/oauth2/authorize

# Gemini API (fallback when ARK not configured)
GEMINI_API_KEY=

# 火山引擎豆包 API（优先使用，设置后 Gemini 自动停用）
# 在 https://console.volcengine.com/ark/region:ark+cn-beijing/endpoint 创建推理接入点
# 推荐模型：Doubao-pro-32k（中文创作强）或 Doubao-lite-32k（更快）
ARK_API_KEY=
ARK_MODEL_ID=

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
